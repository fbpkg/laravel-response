{
  "name": "fbpkg/laravel-response",
  "description": "Fluent response builder for Laravel APIs with clean and consistent JSON structure",
  "keywords": [
    "laravel",
    "response",
    "api",
    "json",
    "fluent",
    "builder",
    "fbpkg"
  ],
  "homepage": "https://github.com/fbpkg/laravel-response",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Farzad Sharifi",
      "email": "dev@farzadblack.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0",
    "illuminate/http": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Fbpkg\\LaravelResponse\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Fbpkg\\LaravelResponse\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Fbpkg\\LaravelResponse\\ResponseServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
